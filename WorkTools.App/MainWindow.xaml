<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WorkTools.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="WorkTools - Template Expander">

    <Grid Padding="24" ColumnSpacing="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left column: Inputs -->
        <Grid Grid.Column="0" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Template Expander" Style="{StaticResource TitleTextBlockStyle}" />

            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Template" VerticalAlignment="Center" />
                <ToggleButton x:Name="FindReplaceToggle" Content="Find &amp; Replace"
                              IsChecked="False" Checked="FindReplaceToggle_Changed"
                              Unchecked="FindReplaceToggle_Changed" Padding="8,4" />
            </StackPanel>

            <Grid x:Name="FindReplaceBar" Grid.Row="2" Visibility="Collapsed"
                  ColumnSpacing="8" RowSpacing="6" Padding="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBox x:Name="FindBox" Grid.Row="0" Grid.Column="0"
                         PlaceholderText="Find..." />
                <Button Grid.Row="0" Grid.Column="1" Content="Find Next"
                        Click="FindNext_Click" Padding="12,6" />

                <TextBox x:Name="ReplaceBox" Grid.Row="1" Grid.Column="0"
                         PlaceholderText="Replace with..." Text="{}{{TagName}}" />
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <Button Content="Replace" Click="Replace_Click" Padding="12,6" />
                    <Button Content="Replace All" Click="ReplaceAll_Click" Padding="12,6" />
                </StackPanel>
            </Grid>

            <ScrollViewer x:Name="TemplateScroll" Grid.Row="3"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="TemplateTextBox"
                         PlaceholderText="Paste template content here..."
                         AcceptsReturn="True" TextWrapping="NoWrap"
                         ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                         ScrollViewer.HorizontalScrollMode="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Hidden"
                         ScrollViewer.VerticalScrollMode="Disabled"
                         TextChanged="Input_TextChanged"
                         SelectionChanged="TextBox_SelectionChanged" />
            </ScrollViewer>

            <TextBlock Grid.Row="4" Text="Tags (one per line)" />
            <ScrollViewer x:Name="TagsScroll" Grid.Row="5" Height="200"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="TagsTextBox"
                         PlaceholderText="Paste tag names here, one per line..."
                         AcceptsReturn="True" TextWrapping="NoWrap"
                         ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                         ScrollViewer.HorizontalScrollMode="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Hidden"
                         ScrollViewer.VerticalScrollMode="Disabled"
                         TextChanged="Input_TextChanged"
                         SelectionChanged="TextBox_SelectionChanged" />
            </ScrollViewer>

            <StackPanel Grid.Row="6" Orientation="Horizontal" Spacing="8">
                <Button x:Name="SaveAsButton" Content="Save As..."
                        Style="{StaticResource AccentButtonStyle}" Click="SaveAs_Click"
                        Padding="24,8" IsEnabled="False" />
                <Button x:Name="ClearButton" Content="Clear"
                        Click="Clear_Click" Padding="24,8" IsEnabled="False" />
            </StackPanel>

            <InfoBar x:Name="StatusBar" Grid.Row="7" IsOpen="False" IsClosable="True" />
        </Grid>

        <!-- Right column: Live preview -->
        <Grid Grid.Column="1" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Output Preview" Style="{StaticResource TitleTextBlockStyle}" />

            <ScrollViewer x:Name="PreviewScroll" Grid.Row="1"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          VerticalAlignment="Stretch">
                <TextBox x:Name="PreviewTextBox"
                         IsReadOnly="True" AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                         ScrollViewer.HorizontalScrollMode="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Hidden"
                         ScrollViewer.VerticalScrollMode="Disabled"
                         PlaceholderText="Preview will appear here as you type..." />
            </ScrollViewer>

            <TextBlock x:Name="StatsText" Grid.Row="2"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="" />
        </Grid>

    </Grid>

</Window>
