<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="WorkTools.Desktop.MainWindow"
        Width="1400"
        Height="900"
        MinWidth="1000"
        MinHeight="700"
        Title="WorkTools Desktop">
  <Grid RowDefinitions="*,Auto" Margin="16" RowSpacing="12">
    <TabControl x:Name="ToolsTabControl" Grid.Row="0">
      <TabItem Header="Template Expander">
        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">
          <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
            <Button x:Name="SaveAsButton" Content="Save As" Click="SaveAs_Click" IsEnabled="False" />
            <Button x:Name="CopyAllButton" Content="Copy All" Click="CopyAll_Click" IsEnabled="False" />
            <Button x:Name="ClearButton" Content="Clear" Click="Clear_Click" IsEnabled="False" />
            <ProgressBar x:Name="ProgressBar" Width="180" IsVisible="False" Minimum="0" Maximum="100" Value="0" />
            <TextBlock x:Name="ProgressText" VerticalAlignment="Center" IsVisible="False" />
          </StackPanel>

          <Grid Grid.Row="1" ColumnDefinitions="1*,1*" ColumnSpacing="16">
            <Grid Grid.Column="0" RowDefinitions="Auto,Auto,*,Auto,*" RowSpacing="8">
              <TextBlock Text="Template" FontWeight="SemiBold" />

              <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                <TextBox x:Name="FindBox" Width="180" Watermark="Find" />
                <TextBox x:Name="ReplaceBox" Width="180" />
                <Button Content="Find Next" Click="FindNext_Click" />
                <Button Content="Replace" Click="Replace_Click" />
                <Button Content="Replace All" Click="ReplaceAll_Click" />
              </StackPanel>

              <TextBox x:Name="TemplateTextBox"
                       Grid.Row="2"
                       TextChanged="Input_TextChanged"
                       AcceptsReturn="True"
                       TextWrapping="NoWrap" />

              <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Replacement lists (one value per line)" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Content="Add Column" Click="AddReplacementColumn_Click" />
              </StackPanel>

              <ScrollViewer Grid.Row="4"
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Disabled">
                <StackPanel x:Name="ReplacementColumnsPanel" Orientation="Horizontal" Spacing="12">
                  <Grid RowDefinitions="Auto,*" RowSpacing="4" Width="240">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6" MinHeight="28">
                      <TextBlock Text="{}{{1}}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </Grid>
                    <TextBox x:Name="TagsTextBox"
                             Grid.Row="1"
                             TextChanged="Input_TextChanged"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap" />
                  </Grid>
                </StackPanel>
              </ScrollViewer>
            </Grid>

            <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto" RowSpacing="8">
              <Border x:Name="ValidationBorder" IsVisible="False" Background="#33B00020" BorderBrush="#66B00020" BorderThickness="1" CornerRadius="6" Padding="10">
                <TextBlock x:Name="ValidationText" Foreground="#FF9A0015" TextWrapping="Wrap" />
              </Border>

              <TabControl x:Name="PreviewTabControl" Grid.Row="1" />

              <TextBlock x:Name="StatsText"
                         Grid.Row="2"
                         FontWeight="SemiBold"
                         Opacity="0.8" />
            </Grid>
          </Grid>
        </Grid>
      </TabItem>

      <TabItem Header="L5K Template Builder">
        <Grid RowDefinitions="Auto,*" RowSpacing="10">
          <TextBlock Text="Drop an L5K or L5X file to extract atomic Input/InOut/Output parameters and build a Crimson template." TextWrapping="Wrap" />

          <Grid Grid.Row="1">
            <Border x:Name="L5kDropBorder"
                    BorderThickness="2"
                    BorderBrush="#553072F5"
                    Background="#113072F5"
                    CornerRadius="8"
                    Padding="20"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
              <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                <TextBlock Text="Drop L5K or L5X File Here" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" />
                <TextBlock Text="Accepted: .L5K, .L5X" Opacity="0.75" HorizontalAlignment="Center" />
              </StackPanel>
            </Border>

            <TextBox x:Name="L5kTemplateTextBox"
                     IsVisible="False"
                     AcceptsReturn="True"
                     TextWrapping="NoWrap" />
          </Grid>
        </Grid>
      </TabItem>
    </TabControl>

    <Border Grid.Row="1" x:Name="StatusBorder" IsVisible="False" Background="#223072F5" BorderBrush="#553072F5" BorderThickness="1" CornerRadius="6" Padding="10">
      <TextBlock x:Name="StatusText" />
    </Border>
  </Grid>
</Window>
